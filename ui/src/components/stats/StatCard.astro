---
interface Props {
  label: string;
  value: string;
  color?: 'primary' | 'success' | 'warning' | 'error' | 'info';
}

const { label, value, color = 'primary' } = Astro.props;

const colorClass = {
  primary: 'text-[var(--color-primary)]',
  success: 'text-[var(--color-success)]',
  warning: 'text-[var(--color-warning)]',
  error: 'text-[var(--color-error)]',
  info: 'text-[var(--color-info)]',
}[color];
---

<div class="flex flex-col gap-1 p-4 rounded-lg bg-[var(--color-surface-low)] border border-[var(--color-surface-high)]">
  <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">
    {label}
  </span>
  <span class={`font-bold text-lg ${colorClass}`}>
    {value}
  </span>
</div>
